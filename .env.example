# LLM Configuration
LLM_PROVIDER=openai            # openai | anthropic | ollama | openai_compatible
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# Provider API Keys
GROQ_API_KEY=
OPENAI_BASE_URL=               # only for openai_compatible provider (e.g. Groq)
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
SERPER_API_KEY=

# Search Configuration
SEARCH_PROVIDER=duckduckgo     # duckduckgo | serper
MAX_SEARCH_RESULTS=5

# Content Extraction
MAX_PAGE_CONTENT_LENGTH=3000
REQUEST_TIMEOUT=10

# Application
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
