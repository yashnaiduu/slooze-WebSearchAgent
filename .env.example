# LLM Configuration
LLM_PROVIDER=openai            # openai | anthropic | ollama | openai_compatible
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# Provider API Keys
OPENAI_API_KEY=
OPENAI_BASE_URL=               # only for openai_compatible provider
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Search Configuration
SEARCH_PROVIDER=duckduckgo     # duckduckgo | tavily | serpapi
MAX_SEARCH_RESULTS=5
TAVILY_API_KEY=
SERPAPI_API_KEY=

# Content Extraction
MAX_PAGE_CONTENT_LENGTH=3000
REQUEST_TIMEOUT=10

# Application
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
